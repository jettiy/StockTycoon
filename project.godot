
; StockTycoon (주식잡스) — Godot 4.7 project
; 증권가에 취직한 청년이 주식/코인으로 돈을 벌고, 집·차·결혼까지 이루는 방치형 게임

config_version=5

[application]

config/name="StockTycoon"
config/description="증권가에 취직한 청년이 주식/코인으로 돈을 벌고, 집·차·결혼까지 이루는 방치형 게임"
run/main_scene="res://scenes/boot.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
MarketSim="*res://scripts/autoload/MarketSim.gd"
SaveManager="*res://scripts/autoload/SaveManager.gd"
AutoTradeManager="*res://scripts/autoload/AutoTradeManager.gd"
EventManager="*res://scripts/autoload/EventManager.gd"
NPCManager="*res://scripts/autoload/NPCManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"
PassiveIncomeManager="*res://scripts/autoload/PassiveIncomeManager.gd"
StoryManager="*res://scripts/autoload/StoryManager.gd"
QuestManager="*res://scripts/autoload/QuestManager.gd"
BusinessManager="*res://scripts/autoload/BusinessManager.gd"
GameClockManager="*res://scripts/autoload/GameClockManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

[input]

ui_select={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)
]
}

[editor_plugins]

enabled=PackedStringArray("easy_charts")

[gui]

theme/custom="res://assets/themes/dark_trading.tres"
theme/custom_font=""

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.063, 0.067, 0.078, 1)
